{
  "name": "trip-compass",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 4010",
    "build": "next build",
    "start": "next start --port 4010",
    "shell:build": "npm --prefix apps/ios-shell install && npm --prefix apps/ios-shell run build",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx scripts/seed.ts",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:smoke": "npm run lint && vitest run tests/unit/smoke.spec.tsx && npm run build"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.16",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.38.0",
    "next": "16.1.7",
    "postgres": "^3.4.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "jsdom": "^29.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
